rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return currentUserExists() && currentRole() == 'admin';
    }

    function validRole(role) {
      return role == 'member' || role == 'seeker' || role == 'creator' || role == 'admin';
    }

    function validOpportunityStatus(value) {
      return value == 'pending' || value == 'published' || value == 'archived';
    }

    function validOpportunityCounters() {
      return request.resource.data.savesCount >= 0
        && request.resource.data.appliedCount >= 0
        && request.resource.data.viewsCount >= 0
        && request.resource.data.savesCount >= resource.data.savesCount - 1
        && request.resource.data.savesCount <= resource.data.savesCount + 1
        && request.resource.data.appliedCount >= resource.data.appliedCount - 1
        && request.resource.data.appliedCount <= resource.data.appliedCount + 1
        && request.resource.data.viewsCount >= resource.data.viewsCount
        && request.resource.data.viewsCount <= resource.data.viewsCount + 1;
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());

      allow create: if signedIn()
        && request.auth.uid == uid
        && validRole(request.resource.data.role);

      allow update: if isAdmin()
        || (
          signedIn()
          && request.auth.uid == uid
          && request.resource.data.role == resource.data.role
        );

      allow delete: if isAdmin();

      match /states/{opportunityId} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }

      match /notifications/{notificationId} {
        allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow create: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow update: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow delete: if isAdmin();
      }
    }

    match /opportunities/{opportunityId} {
      allow read: if resource.data.status == 'published'
        || isAdmin()
        || (signedIn() && resource.data.creatorUid == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.creatorUid == request.auth.uid
        && validOpportunityStatus(request.resource.data.status)
        && (
          request.resource.data.status == 'pending'
          || (isAdmin() && request.resource.data.status == 'published')
        );

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.creatorUid == request.auth.uid
          && request.resource.data.creatorUid == resource.data.creatorUid
          && request.resource.data.status == resource.data.status
        )
        || (
          signedIn()
          && resource.data.status == 'published'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'savesCount',
            'appliedCount',
            'viewsCount',
            'updatedAt'
          ])
          && validOpportunityCounters()
        );

      allow delete: if isAdmin()
        || (signedIn() && resource.data.creatorUid == request.auth.uid);

      match /comments/{commentId} {
        allow read: if get(/databases/$(database)/documents/opportunities/$(opportunityId)).data.status == 'published'
          || isAdmin()
          || (
            signedIn()
            && get(/databases/$(database)/documents/opportunities/$(opportunityId)).data.creatorUid == request.auth.uid
          );
        allow create: if signedIn()
          && get(/databases/$(database)/documents/opportunities/$(opportunityId)).data.status == 'published';
        allow update, delete: if isAdmin();
      }
    }
  }
}
