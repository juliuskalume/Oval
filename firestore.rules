rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isBootstrapAdminEmail() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email.matches('(?i)^(juliuskalume906@gmail\\.com|sentira\\.official@gmail\\.com)$');
    }

    function isAdmin() {
      return isBootstrapAdminEmail()
        || (currentUserExists() && currentRole() == 'admin');
    }

    function validRole(role) {
      return role == 'member' || role == 'admin';
    }

    function validOpportunityStatus(value) {
      return value == 'pending' || value == 'published' || value == 'archived';
    }

    function validOpportunityCounters() {
      return request.resource.data.savesCount >= 0
        && request.resource.data.appliedCount >= 0
        && request.resource.data.commentsCount >= 0
        && request.resource.data.likesCount >= 0
        && request.resource.data.viewsCount >= 0
        && request.resource.data.savesCount >= resource.data.savesCount - 1
        && request.resource.data.savesCount <= resource.data.savesCount + 1
        && request.resource.data.appliedCount >= resource.data.appliedCount - 1
        && request.resource.data.appliedCount <= resource.data.appliedCount + 1
        && request.resource.data.commentsCount >= resource.data.commentsCount - 1
        && request.resource.data.commentsCount <= resource.data.commentsCount + 1
        && request.resource.data.likesCount >= resource.data.likesCount - 1
        && request.resource.data.likesCount <= resource.data.likesCount + 1
        && request.resource.data.viewsCount >= resource.data.viewsCount
        && request.resource.data.viewsCount <= resource.data.viewsCount + 1;
    }

    function validCommentPayload() {
      return request.resource.data.keys().hasOnly([
          'authorUid',
          'authorName',
          'authorHandle',
          'authorPhotoURL',
          'body',
          'parentId',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.authorUid is string
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 80
        && request.resource.data.authorHandle is string
        && request.resource.data.authorHandle.size() > 0
        && request.resource.data.authorHandle.size() <= 40
        && request.resource.data.authorPhotoURL is string
        && request.resource.data.authorPhotoURL.size() > 0
        && request.resource.data.authorPhotoURL.size() <= 1000
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 280
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (
          request.resource.data.parentId == null
          || (
            request.resource.data.parentId is string
            && request.resource.data.parentId.size() > 0
          )
        );
    }

    function validCommentUpdatePayload() {
      return request.resource.data.keys().hasOnly([
          'authorUid',
          'authorName',
          'authorHandle',
          'authorPhotoURL',
          'body',
          'parentId',
          'createdAt',
          'updatedAt',
          'deletedAt'
        ])
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.authorName == resource.data.authorName
        && request.resource.data.authorHandle == resource.data.authorHandle
        && request.resource.data.authorPhotoURL == resource.data.authorPhotoURL
        && request.resource.data.parentId == resource.data.parentId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp
        && (
          request.resource.data.deletedAt == resource.data.deletedAt
          || request.resource.data.deletedAt is timestamp
        )
        && (
          (
            request.resource.data.deletedAt == resource.data.deletedAt
            && request.resource.data.body is string
            && request.resource.data.body.size() > 0
            && request.resource.data.body.size() <= 280
          )
          || (
            request.resource.data.deletedAt is timestamp
            && request.resource.data.body == ""
          )
        );
    }

    function validFollowDoc(expectedUid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'displayName',
          'username',
          'photoURL',
          'createdAt'
        ])
        && request.resource.data.uid == expectedUid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 80
        && request.resource.data.username is string
        && request.resource.data.username.size() <= 40
        && request.resource.data.photoURL is string
        && request.resource.data.photoURL.size() > 0
        && request.resource.data.photoURL.size() <= 1000
        && request.resource.data.createdAt is timestamp;
    }

    function validNotificationPayload() {
      return request.resource.data.keys().hasOnly([
          'type',
          'title',
          'body',
          'read',
          'createdAt',
          'opportunityId',
          'profileUid'
        ])
        && request.resource.data.type is string
        && request.resource.data.type.size() > 0
        && request.resource.data.type.size() <= 50
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 280
        && request.resource.data.read == false
        && request.resource.data.createdAt is timestamp
        && (
          !request.resource.data.keys().hasAny(['opportunityId'])
          || request.resource.data.opportunityId is string
        )
        && (
          !request.resource.data.keys().hasAny(['profileUid'])
          || request.resource.data.profileUid is string
        );
    }

    match /users/{uid} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.auth.uid == uid
        && validRole(request.resource.data.role)
        && (
          request.resource.data.role == 'member'
          || (request.resource.data.role == 'admin' && isBootstrapAdminEmail())
        );

      allow update: if (isAdmin() && validRole(request.resource.data.role))
        || (
          signedIn()
          && request.auth.uid == uid
          && request.resource.data.role == resource.data.role
        );

      allow delete: if isAdmin();

      match /states/{opportunityId} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }

      match /notifications/{notificationId} {
        allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow create: if signedIn() && validNotificationPayload();
        allow update: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow delete: if isAdmin();
      }

      match /following/{targetUid} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.auth.uid == uid
          && uid != targetUid
          && validFollowDoc(targetUid);
        allow delete: if signedIn() && request.auth.uid == uid;
      }

      match /followers/{followerUid} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.auth.uid == followerUid
          && followerUid != uid
          && validFollowDoc(followerUid);
        allow delete: if signedIn() && request.auth.uid == followerUid;
      }
    }

    match /opportunities/{opportunityId} {
      allow read: if resource.data.status == 'published'
        || isAdmin()
        || (signedIn() && resource.data.creatorUid == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.creatorUid == request.auth.uid
        && validOpportunityStatus(request.resource.data.status)
        && (
          request.resource.data.status == 'pending'
          || (isAdmin() && request.resource.data.status == 'published')
        );

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.creatorUid == request.auth.uid
          && request.resource.data.creatorUid == resource.data.creatorUid
          && request.resource.data.status == resource.data.status
        )
        || (
          signedIn()
          && resource.data.status == 'published'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'savesCount',
            'appliedCount',
            'commentsCount',
            'likesCount',
            'viewsCount',
            'updatedAt'
          ])
          && validOpportunityCounters()
        );

      allow delete: if isAdmin()
        || (signedIn() && resource.data.creatorUid == request.auth.uid);

      match /comments/{commentId} {
        allow read: if get(/databases/$(database)/documents/opportunities/$(opportunityId)).data.status == 'published'
          || isAdmin()
          || (
            signedIn()
            && get(/databases/$(database)/documents/opportunities/$(opportunityId)).data.creatorUid == request.auth.uid
          );
        allow create: if signedIn()
          && get(/databases/$(database)/documents/opportunities/$(opportunityId)).data.status == 'published'
          && get(/databases/$(database)/documents/opportunities/$(opportunityId)).data.allowComments != false
          && validCommentPayload();
        allow update: if isAdmin()
          || (
            signedIn()
            && resource.data.authorUid == request.auth.uid
            && validCommentUpdatePayload()
          );
        allow delete: if isAdmin()
          || (
            signedIn()
            && resource.data.authorUid == request.auth.uid
          );
      }
    }
  }
}
