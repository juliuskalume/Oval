rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedInFor(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isImageUpload() {
      return request.resource.contentType.matches('image/.*');
    }

    function isVideoUpload() {
      return request.resource.contentType.matches('video/.*');
    }

    match /opportunity-media/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if signedInFor(uid)
        && (
          (isImageUpload() && request.resource.size <= 5 * 1024 * 1024)
          || (isVideoUpload() && request.resource.size <= 10 * 1024 * 1024)
        );
    }

    match /opportunity-attachments/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if signedInFor(uid)
        && request.resource.size <= 5 * 1024 * 1024;
    }

    match /profile-avatars/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if signedInFor(uid)
        && isImageUpload()
        && request.resource.size <= 5 * 1024 * 1024;
    }
  }
}
